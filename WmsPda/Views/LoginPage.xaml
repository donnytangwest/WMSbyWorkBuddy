<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WmsPda.Views.LoginPage"
             Title=""
             BackgroundColor="#F0F4F8">

    <ScrollView>
        <VerticalStackLayout Padding="24,60,24,24" Spacing="20">

            <!-- Logo 区域 -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,0,0,32">
                <Border BackgroundColor="#1565C0"
                        StrokeShape="RoundRectangle 16"
                        HeightRequest="80" WidthRequest="80"
                        HorizontalOptions="Center">
                    <Label Text="WMS"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <Label Text="仓库管理系统"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#1565C0"
                       HorizontalOptions="Center" />
                <Label Text="PDA 移动终端"
                       FontSize="14"
                       TextColor="#888888"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- 表单区域 -->
            <VerticalStackLayout Spacing="16" Padding="0">

                <!-- 用户名 -->
                <Label Text="用户名"
                       FontSize="14"
                       TextColor="#555555" />
                <Border Stroke="#CCCCCC"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        BackgroundColor="White">
                    <Entry Placeholder="请输入用户名"
                           Text="{Binding Username}"
                           FontSize="18"
                           HeightRequest="52"
                           Margin="12,0"
                           ReturnType="Next" />
                </Border>

                <!-- 密码 -->
                <Label Text="密码"
                       FontSize="14"
                       TextColor="#555555" />
                <Border Stroke="#CCCCCC"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8"
                        BackgroundColor="White">
                    <Entry Placeholder="请输入密码"
                           Text="{Binding Password}"
                           IsPassword="True"
                           FontSize="18"
                           HeightRequest="52"
                           Margin="12,0"
                           ReturnType="Done" />
                </Border>

                <!-- 提示信息 -->
                <Label Text="{Binding Message}"
                       FontSize="14"
                       TextColor="{Binding MessageColor}"
                       HorizontalOptions="Center"
                       IsVisible="{Binding HasMessage}" />

                <!-- 登录按钮 -->
                <Button Text="{Binding LoginButtonText}"
                        Command="{Binding LoginCommand}"
                        IsEnabled="{Binding IsNotLoading}"
                        BackgroundColor="#1565C0"
                        TextColor="White"
                        FontSize="18"
                        FontAttributes="Bold"
                        HeightRequest="56"
                        CornerRadius="8" />

                <!-- 注册入口 -->
                <Button Text="没有账号？点此注册"
                        Command="{Binding GoToRegisterCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#1565C0"
                        FontSize="16"
                        HeightRequest="48"
                        CornerRadius="8"
                        BorderColor="#1565C0"
                        BorderWidth="1.5" />

            </VerticalStackLayout>

            <!-- 版本信息 -->
            <Label Text="v1.0  ·  WMS 系统"
                   FontSize="12"
                   TextColor="#AAAAAA"
                   HorizontalOptions="Center"
                   Margin="0,16,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
