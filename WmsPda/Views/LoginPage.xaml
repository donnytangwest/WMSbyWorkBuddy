<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="WmsPda.Views.LoginPage"
             Title=""
             BackgroundColor="#F5F7FA"
             NavigationPage.HasNavigationBar="False">

    <ScrollView>
        <VerticalStackLayout Padding="28,60,28,28" Spacing="0">

            <!-- Logo 区域 -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="8" Margin="0,0,0,48">
                <Frame BackgroundColor="{StaticResource Primary}"
                       CornerRadius="20"
                       HeightRequest="80" WidthRequest="80"
                       HorizontalOptions="Center"
                       Padding="0"
                       HasShadow="True">
                    <Label Text="WMS"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Frame>
                <Label Text="仓库管理系统"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="{StaticResource Primary}"
                       HorizontalOptions="Center" />
                <Label Text="PDA 移动终端"
                       FontSize="14"
                       TextColor="#888888"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- 表单卡片 -->
            <Frame BackgroundColor="White"
                   CornerRadius="12"
                   HasShadow="True"
                   Padding="24,28">
                <VerticalStackLayout Spacing="20">

                    <!-- 用户名 -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="用户名" Style="{StaticResource FieldLabel}" />
                        <Border Stroke="#DDDDDD" StrokeThickness="1.5" StrokeShape="RoundRectangle 8">
                            <Entry Placeholder="请输入用户名"
                                   Text="{Binding Username}"
                                   Style="{StaticResource PdaEntry}"
                                   ReturnType="Next"
                                   Margin="12,0" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- 密码 -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="密码" Style="{StaticResource FieldLabel}" />
                        <Border Stroke="#DDDDDD" StrokeThickness="1.5" StrokeShape="RoundRectangle 8">
                            <Entry Placeholder="请输入密码"
                                   Text="{Binding Password}"
                                   IsPassword="True"
                                   Style="{StaticResource PdaEntry}"
                                   ReturnType="Done"
                                   ReturnCommand="{Binding LoginCommand}"
                                   Margin="12,0" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- 提示信息 -->
                    <Label Text="{Binding Message}"
                           IsVisible="{Binding Message, Converter={x:StaticResource StringNotEmptyConverter}}"
                           FontSize="14"
                           HorizontalOptions="Center">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsError}" Value="True">
                                <Setter Property="TextColor" Value="{StaticResource ErrorColor}" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsError}" Value="False">
                                <Setter Property="TextColor" Value="{StaticResource SuccessColor}" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>

                    <!-- 登录按钮 -->
                    <Button Text="{Binding IsLoading, Converter={x:StaticResource LoadingTextConverter}, ConverterParameter='登录中...|登录'}"
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding IsLoading, Converter={x:StaticResource InverseBoolConverter}}"
                            Style="{StaticResource PdaButton}" />

                    <!-- 注册入口 -->
                    <Button Text="没有账号？点此注册"
                            Command="{Binding GoToRegisterCommand}"
                            Style="{StaticResource PdaButtonSecondary}" />

                </VerticalStackLayout>
            </Frame>

            <!-- 版本信息 -->
            <Label Text="v1.0  ·  WMS 系统"
                   FontSize="12"
                   TextColor="#AAAAAA"
                   HorizontalOptions="Center"
                   Margin="0,24,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
