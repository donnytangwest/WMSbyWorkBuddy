@page "/register"
@using WmsWeb.Database
@inject DatabaseHelper Db
@inject NavigationManager Navigation

<PageTitle>注册 - WMS 系统</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow">
                <div class="card-header bg-info text-white text-center">
                    <h4 class="mb-0">新用户注册</h4>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="regUsername" class="form-label">用户名 <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="regUsername" @bind="Username" 
                                   placeholder="至少 3 个字符" />
                            <div class="form-text">用于登录的账号，不可重复</div>
                        </div>
                        <div class="col-md-6">
                            <label for="email" class="form-label">邮箱</label>
                            <input type="email" class="form-control" id="email" @bind="Email" 
                                   placeholder="可选，用于接收通知" />
                        </div>
                        <div class="col-md-6">
                            <label for="regPassword" class="form-label">密码 <span class="text-danger">*</span></label>
                            <input type="password" class="form-control" id="regPassword" @bind="Password" 
                                   placeholder="至少 6 个字符" />
                        </div>
                        <div class="col-md-6">
                            <label for="confirmPassword" class="form-label">确认密码 <span class="text-danger">*</span></label>
                            <input type="password" class="form-control" id="confirmPassword" @bind="ConfirmPassword" 
                                   placeholder="再次输入密码" />
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Message))
                    {
                        <div class="alert @(IsSuccess ? @"alert-success" : @"alert-danger") mt-4">
                            @Message
                        </div>
                    }

                    <div class="d-grid gap-2 mt-4">
                        <button class="btn btn-info" @onclick="HandleRegister" disabled="@IsLoading">
                            @if (IsLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                            }
                            提交注册
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="GoToLogin">
                            已有账号？返回登录
                        </button>
                    </div>
                </div>
                <div class="card-footer text-center text-muted small">
                    注册成功后即可使用 WMS 系统全部功能
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string Username { get; set; } = "";
    private string Password { get; set; } = "";
    private string ConfirmPassword { get; set; } = "";
    private string Email { get; set; } = "";
    private string Message { get; set; } = "";
    private bool IsSuccess { get; set; } = false;
    private bool IsLoading { get; set; } = false;

    private void GoToLogin()
    {
        Navigation.NavigateTo("/login");
    }

    private async Task HandleRegister()
    {
        if (string.IsNullOrWhiteSpace(Username) || Username.Length < 3)
        {
            Message = "用户名至少需要 3 个字符";
            IsSuccess = false;
            return;
        }

        if (string.IsNullOrWhiteSpace(Password) || Password.Length < 6)
        {
            Message = "密码至少需要 6 个字符";
            IsSuccess = false;
            return;
        }

        if (Password != ConfirmPassword)
        {
            Message = "两次输入的密码不一致";
            IsSuccess = false;
            return;
        }

        IsLoading = true;
        await Task.Delay(400);

        var (success, msg) = Db.Register(Username, Password, Email);
        IsSuccess = success;
        Message = msg;

        IsLoading = false;

        if (success)
        {
            await Task.Delay(1000);
            Navigation.NavigateTo("/login");
        }
    }
}
