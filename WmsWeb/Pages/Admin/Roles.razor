@page "/admin/roles"
@using WmsCore.Database
@using WmsWeb.Services
@inject PermissionHelper PermHelper
@inject AuthState Auth

<PageTitle>角色管理 - WMS 系统</PageTitle>

@if (!Auth.Has("menu.admin.roles"))
{
    <div class="alert alert-danger"><i class="bi bi-shield-x me-2"></i>您没有访问此页面的权限。</div>
    return;
}

<div class="container-fluid px-4">
    <h1 class="mt-4">角色管理</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item"><a href="/dashboard">首页</a></li>
        <li class="breadcrumb-item">系统管理</li>
        <li class="breadcrumb-item active">角色管理</li>
    </ol>

    @if (!string.IsNullOrEmpty(AlertMsg))
    {
        <div class="alert @(AlertSuccess ? "alert-success" : "alert-danger") alert-dismissible py-2">
            <i class="bi bi-@(AlertSuccess ? "check-circle" : "exclamation-circle") me-2"></i>@AlertMsg
            <button type="button" class="btn-close" @onclick="() => AlertMsg = string.Empty"></button>
        </div>
    }

    <div class="row g-4">
        <!-- 左：角色列表 -->
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-person-badge me-2"></i>角色列表</span>
                    <button class="btn btn-sm btn-primary" @onclick="ShowAddRoleForm">
                        <i class="bi bi-plus-lg"></i>
                    </button>
                </div>
                <div class="card-body p-0">
                    @foreach (var role in RoleList)
                    {
                        <div class="p-3 border-bottom @(SelectedRole?.Code == role.Code ? "bg-primary bg-opacity-10 border-start border-primary border-3" : "") cursor-pointer"
                             style="cursor:pointer;" @onclick="() => SelectRole(role)">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <div class="fw-semibold">@role.Name</div>
                                    <code class="text-muted small">@role.Code</code>
                                    @if (!string.IsNullOrEmpty(role.Description))
                                    {
                                        <div class="text-muted small mt-1">@role.Description</div>
                                    }
                                </div>
                                <span class="badge bg-secondary">@role.PermissionCodes.Count 个权限</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- 右：角色详情 / 新增表单 / 权限分配 -->
        <div class="col-lg-8">
            @if (ShowingAddForm)
            {
                <!-- 新增角色表单 -->
                <div class="card shadow-sm">
                    <div class="card-header fw-semibold">
                        <i class="bi bi-plus-circle me-2"></i>新增角色
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">角色名称 <span class="text-danger">*</span></label>
                                <input class="form-control" @bind="NewRoleName" placeholder="如 仓管主管" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">角色编码 <span class="text-danger">*</span></label>
                                <input class="form-control" @bind="NewRoleCode" placeholder="如 warehouse_manager（英文唯一）" />
                            </div>
                            <div class="col-12">
                                <label class="form-label">描述</label>
                                <input class="form-control" @bind="NewRoleDesc" placeholder="可选" />
                            </div>
                            <div class="col-12">
                                <button class="btn btn-primary me-2" @onclick="AddRole">
                                    <i class="bi bi-check-lg me-1"></i>创建角色
                                </button>
                                <button class="btn btn-secondary" @onclick="() => ShowingAddForm = false">取消</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (SelectedRole != null)
            {
                <!-- 已选角色：权限配置 -->
                <div class="card shadow-sm">
                    <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                        <span><i class="bi bi-shield-check me-2"></i>「@SelectedRole.Name」的权限配置</span>
                        <div class="d-flex gap-2">
                            <button class="btn btn-sm btn-success" @onclick="SaveRolePermissions">
                                <i class="bi bi-check-lg me-1"></i>保存权限
                            </button>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteRole(SelectedRole.Code)">
                                <i class="bi bi-trash me-1"></i>删除角色
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <!-- 全选/取消 -->
                        <div class="mb-3">
                            <button class="btn btn-sm btn-outline-secondary me-2" @onclick="SelectAll">全选</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="ClearAll">全部取消</button>
                        </div>

                        @foreach (var group in AllPermGrouped)
                        {
                            <div class="mb-4">
                                <h6 class="text-muted border-bottom pb-1 mb-2">
                                    <i class="bi bi-folder2 me-1"></i>@group.Key
                                </h6>
                                <div class="row row-cols-1 row-cols-md-2 g-2">
                                    @foreach (var p in group.Value)
                                    {
                                        <div class="col">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox"
                                                       id="perm_@p.Code"
                                                       checked="@SelectedPermCodes.Contains(p.Code)"
                                                       @onchange="e => TogglePerm(p.Code, (bool)e.Value!)" />
                                                <label class="form-check-label" for="perm_@p.Code">
                                                    <span class="badge @TypeBadge(p.Type) me-1 small">@TypeLabel(p.Type)</span>
                                                    @p.Name
                                                    <br /><code class="text-muted" style="font-size:0.72rem;">@p.Code</code>
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm">
                    <div class="card-body text-center text-muted py-5">
                        <i class="bi bi-arrow-left fs-3 mb-2 d-block"></i>
                        请从左侧选择一个角色来配置权限
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private List<Role> RoleList = new();
    private List<PermissionItem> AllPerms = new();
    private Dictionary<string, List<PermissionItem>> AllPermGrouped = new();
    private Role? SelectedRole = null;
    private HashSet<string> SelectedPermCodes = new();

    private bool ShowingAddForm = false;
    private string NewRoleName = "";
    private string NewRoleCode = "";
    private string NewRoleDesc = "";
    private string AlertMsg     = "";
    private bool   AlertSuccess = false;

    protected override void OnInitialized() => LoadData();

    private void LoadData()
    {
        RoleList = PermHelper.GetAllRoles();
        AllPerms = PermHelper.GetAllPermissions();
        AllPermGrouped = AllPerms
            .GroupBy(p => string.IsNullOrEmpty(p.Group) ? "未分组" : p.Group)
            .OrderBy(g => g.Key)
            .ToDictionary(g => g.Key, g => g.ToList());
    }

    private void SelectRole(Role role)
    {
        ShowingAddForm    = false;
        SelectedRole      = role;
        SelectedPermCodes = new HashSet<string>(role.PermissionCodes);
    }

    private void ShowAddRoleForm()
    {
        ShowingAddForm = true;
        SelectedRole   = null;
        NewRoleName = NewRoleCode = NewRoleDesc = "";
    }

    private void AddRole()
    {
        var (success, msg) = PermHelper.AddRole(new Role
        {
            Name        = NewRoleName,
            Code        = NewRoleCode,
            Description = NewRoleDesc,
        });
        AlertMsg     = msg;
        AlertSuccess = success;
        if (success) { ShowingAddForm = false; LoadData(); }
    }

    private void SaveRolePermissions()
    {
        if (SelectedRole == null) return;
        var (success, msg) = PermHelper.SetRolePermissions(SelectedRole.Code, SelectedPermCodes);
        AlertMsg     = msg;
        AlertSuccess = success;
        if (success) LoadData();
    }

    private void DeleteRole(string code)
    {
        var (success, msg) = PermHelper.DeleteRole(code);
        AlertMsg     = msg;
        AlertSuccess = success;
        if (success) { SelectedRole = null; LoadData(); }
    }

    private void TogglePerm(string code, bool isChecked)
    {
        if (isChecked) SelectedPermCodes.Add(code);
        else SelectedPermCodes.Remove(code);
    }

    private void SelectAll() => SelectedPermCodes = new HashSet<string>(AllPerms.Select(p => p.Code));
    private void ClearAll()  => SelectedPermCodes = new HashSet<string>();

    private static string TypeLabel(PermissionType t) => t switch
    {
        PermissionType.Menu    => "菜单",
        PermissionType.SubMenu => "子菜单",
        _                      => "按钮",
    };
    private static string TypeBadge(PermissionType t) => t switch
    {
        PermissionType.Menu    => "bg-primary",
        PermissionType.SubMenu => "bg-info text-dark",
        _                      => "bg-secondary",
    };
}
