@inherits LayoutComponentBase
@using WmsWeb.Services
@inject AuthState Auth
@inject NavigationManager Navigation
@implements IDisposable

<div class="d-flex" style="min-height:100vh;">

    <!-- 侧边栏 -->
    <nav class="sidebar d-flex flex-column p-3" style="width:220px; flex-shrink:0;">
        <div class="text-white mb-4 mt-2">
            <div class="fw-bold fs-5"><i class="bi bi-boxes me-2"></i>WMS 系统</div>
            <div style="font-size:0.75rem; opacity:0.6;">仓库管理平台</div>
        </div>
        <ul class="nav flex-column gap-1 flex-grow-1">

            @* 仪表盘（无权限限制，登录即可见）*@
            <li class="nav-item">
                <NavLink class="nav-link" href="/dashboard" Match="NavLinkMatch.All">
                    <i class="bi bi-speedometer2 me-2"></i>仪表盘
                </NavLink>
            </li>

            @* 仓库管理 *@
            @if (Auth.Has("menu.warehouse"))
            {
                <li class="nav-item">
                    <NavLink class="nav-link" href="/warehouse">
                        <i class="bi bi-buildings me-2"></i>仓库管理
                    </NavLink>
                </li>
            }

            @* 入库管理 *@
            @if (Auth.Has("menu.inbound"))
            {
                <li class="nav-item">
                    <NavLink class="nav-link" href="/inbound">
                        <i class="bi bi-arrow-down-left me-2"></i>入库管理
                    </NavLink>
                </li>
            }

            @* 出库管理 *@
            @if (Auth.Has("menu.outbound"))
            {
                <li class="nav-item">
                    <NavLink class="nav-link" href="/outbound">
                        <i class="bi bi-arrow-up-right me-2"></i>出库管理
                    </NavLink>
                </li>
            }

            @* 库存查询 *@
            @if (Auth.Has("menu.inventory"))
            {
                <li class="nav-item">
                    <NavLink class="nav-link" href="/inventory">
                        <i class="bi bi-clipboard-data me-2"></i>库存查询
                    </NavLink>
                </li>
            }

            @* 系统管理（管理员可见）*@
            @if (Auth.Has("menu.admin"))
            {
                <li class="nav-item mt-2">
                    <div class="text-white px-2 mb-1" style="font-size:0.7rem;opacity:0.5;letter-spacing:1px;">系统管理</div>
                </li>

                @if (Auth.Has("menu.admin.permissions"))
                {
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/admin/permissions">
                            <i class="bi bi-shield-check me-2"></i>权限点管理
                        </NavLink>
                    </li>
                }

                @if (Auth.Has("menu.admin.roles"))
                {
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/admin/roles">
                            <i class="bi bi-person-badge me-2"></i>角色管理
                        </NavLink>
                    </li>
                }

                @if (Auth.Has("menu.admin.users"))
                {
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/admin/users">
                            <i class="bi bi-people me-2"></i>用户管理
                        </NavLink>
                    </li>
                }
            }

        </ul>

        <!-- 底部：当前用户信息 -->
        <div class="text-white mt-auto pt-3 border-top border-white border-opacity-25">
            @if (Auth.IsLoggedIn)
            {
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="bi bi-person-circle fs-5"></i>
                    <span style="font-size:0.85rem;">@Auth.CurrentUser!.Username</span>
                </div>
            }
            <button class="btn btn-sm btn-outline-light w-100" @onclick="HandleLogout">
                <i class="bi bi-box-arrow-right me-1"></i>退出登录
            </button>
            <div class="text-center mt-2" style="font-size:0.65rem; opacity:0.4;">v1.0 · Blazor Server</div>
        </div>
    </nav>

    <!-- 主内容区 -->
    <div class="flex-grow-1 d-flex flex-column">
        <!-- 顶部栏 -->
        <header class="bg-white border-bottom px-4 py-2 d-flex align-items-center justify-content-between" style="height:56px;">
            <span class="text-muted fw-semibold">WMS 仓库管理系统</span>
            @if (Auth.IsLoggedIn)
            {
                <span class="badge bg-secondary">
                    <i class="bi bi-person me-1"></i>@Auth.CurrentUser!.Username
                </span>
            }
        </header>

        <!-- 页面内容 -->
        <main class="flex-grow-1 p-4 bg-light">
            @Body
        </main>
    </div>
</div>

<div id="blazor-error-ui">
    <span>出现了意外错误，请刷新页面。</span>
    <a href="" class="reload">刷新</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    protected override void OnInitialized()
    {
        Auth.OnChanged += StateHasChanged;
    }

    private void HandleLogout()
    {
        Auth.Logout();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        Auth.OnChanged -= StateHasChanged;
    }
}
