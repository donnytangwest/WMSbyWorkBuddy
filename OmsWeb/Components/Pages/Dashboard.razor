@page "/dashboard"
@rendermode InteractiveServer
@inject OmsAuthState Auth
@inject OmsDatabaseHelper Db
@inject NavigationManager Navigation

<PageTitle>仪表盘 - OMS 系统</PageTitle>

@if (!Auth.IsLoggedIn)
{
    <div class="text-center py-5">
        <p>请先 <a href="/login">登录</a></p>
    </div>
    return;
}

<div class="container-fluid px-4">
    <h1 class="mt-4 fw-bold">仪表盘</h1>
    <ol class="breadcrumb mb-4">
        <li class="breadcrumb-item active">首页</li>
    </ol>

    <!-- 统计卡片 -->
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #1a3a5c !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 p-3" style="background:#e8f0fe;">
                        <i class="bi bi-box-seam fs-4" style="color:#1a3a5c;"></i>
                    </div>
                    <div>
                        <div class="text-muted small">产品总数</div>
                        <div class="fw-bold fs-4">@Stats.ProductCount</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #0d6efd !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 p-3 bg-primary bg-opacity-10">
                        <i class="bi bi-receipt fs-4 text-primary"></i>
                    </div>
                    <div>
                        <div class="text-muted small">订单总数</div>
                        <div class="fw-bold fs-4">@Stats.OrderCount</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #198754 !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 p-3 bg-success bg-opacity-10">
                        <i class="bi bi-check2-circle fs-4 text-success"></i>
                    </div>
                    <div>
                        <div class="text-muted small">已完成订单</div>
                        <div class="fw-bold fs-4">@Stats.CompletedCount</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100" style="border-left:4px solid #ffc107 !important;">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-3 p-3 bg-warning bg-opacity-10">
                        <i class="bi bi-hourglass-split fs-4 text-warning"></i>
                    </div>
                    <div>
                        <div class="text-muted small">待处理订单</div>
                        <div class="fw-bold fs-4">@Stats.PendingCount</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 快捷入口 -->
    <div class="row g-4">
        @if (Auth.Has("menu.products"))
        {
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center p-4 h-100" style="cursor:pointer;"
                     @onclick='() => Navigation.NavigateTo("/products")'>
                    <i class="bi bi-box-seam fs-1 mb-3" style="color:#1a3a5c;"></i>
                    <h5>产品管理</h5>
                    <p class="text-muted small">管理 SKU 产品信息</p>
                </div>
            </div>
        }
        @if (Auth.Has("menu.orders"))
        {
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center p-4 h-100" style="cursor:pointer;"
                     @onclick='() => Navigation.NavigateTo("/orders")'>
                    <i class="bi bi-receipt fs-1 mb-3 text-primary"></i>
                    <h5>订单管理</h5>
                    <p class="text-muted small">创建和跟踪订单</p>
                </div>
            </div>
        }
        @if (Auth.Has("menu.inventory"))
        {
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center p-4 h-100" style="cursor:pointer;"
                     @onclick='() => Navigation.NavigateTo("/inventory")'>
                    <i class="bi bi-clipboard-data fs-1 mb-3 text-info"></i>
                    <h5>库存查询</h5>
                    <p class="text-muted small">实时查询 WMS 库存</p>
                </div>
            </div>
        }
        @if (Auth.Has("menu.admin"))
        {
            <div class="col-md-3">
                <div class="card border-0 shadow-sm text-center p-4 h-100" style="cursor:pointer;"
                     @onclick='() => Navigation.NavigateTo("/admin/users")'>
                    <i class="bi bi-gear fs-1 mb-3 text-secondary"></i>
                    <h5>系统管理</h5>
                    <p class="text-muted small">用户/角色/权限配置</p>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private DashboardStats Stats = new();

    protected override void OnInitialized()
    {
        var orders   = Db.GetAllOrders();
        var products = Db.GetAllProducts();
        Stats = new DashboardStats
        {
            ProductCount   = products.Count,
            OrderCount     = orders.Count,
            CompletedCount = orders.Count(o => o.Status == OrderStatus.Completed),
            PendingCount   = orders.Count(o => o.Status == OrderStatus.Submitted || o.Status == OrderStatus.Processing),
        };
    }

    private class DashboardStats
    {
        public int ProductCount   { get; set; }
        public int OrderCount     { get; set; }
        public int CompletedCount { get; set; }
        public int PendingCount   { get; set; }
    }
}
